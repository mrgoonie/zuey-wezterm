# Ghostty Configuration
# Converted from WezTerm config

# ===== Working Directory =====
working-directory = ~/www

# ===== Window =====
macos-titlebar-style = tabs
window-width = 160
window-height = 45
window-padding-x = 12
window-padding-y = 12
background-opacity = 0.97
background-blur-radius = 20
fullscreen = false

# ===== Appearance =====
theme = tokyonight
font-family = JetBrains Mono
font-style = Medium
font-size = 12
adjust-cell-height = 20%

# ===== Cursor =====
cursor-style = bar
cursor-style-blink = true

# ===== Scrollback =====
scrollback-limit = 10000

# ===== Tab Bar =====
gtk-tabs-location = bottom
window-save-state = always

# ===== Mouse =====
mouse-hide-while-typing = true

# ===== Copy/Paste =====
copy-on-select = clipboard

# ===== Shell Integration =====
shell-integration = zsh

# ===== Keybindings =====
# Word navigation (Option + Arrow)
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf

# Line navigation (Cmd + Arrow)
keybind = super+left=text:\x01
keybind = super+right=text:\x05

# Delete whole line (Cmd + Backspace)
keybind = super+backspace=text:\x15

# Split panes
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# Pane navigation
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# Close pane/tab
keybind = super+w=close_surface

# New tab
keybind = super+t=new_tab

# Tab navigation
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab

# Clear scrollback
keybind = super+k=clear_screen

# Toggle fullscreen
keybind = super+shift+enter=toggle_fullscreen

# Zoom pane
keybind = super+z=toggle_split_zoom

# Resize panes
keybind = super+ctrl+left=resize_split:left,50
keybind = super+ctrl+right=resize_split:right,50
keybind = super+ctrl+up=resize_split:up,50
keybind = super+ctrl+down=resize_split:down,50

# Quick terminal (global hotkey)
keybind = global:super+grave_accent=toggle_quick_terminal
